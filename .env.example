# ──────────────────────────────────────────────────────────────────────────
#  stock-studio  —  environment
#  Copy to `.env` and fill in. Never commit the real .env.
# ──────────────────────────────────────────────────────────────────────────

# --- LLM backend (local Ollama or any OpenAI-compatible server) ----------
# Base URL of the OpenAI-compatible API. Ollama exposes /v1.
#   host-run:        http://localhost:11434/v1   (or http://ollama:11434/v1)
#   in Docker:       the compose file maps the host's gateway to "ollama"
LLM_BASE_URL=http://ollama:11434/v1
# Optional bearer token for gated gateways. Ollama ignores it; leave blank.
# (Can also be saved from the dashboard Credentials panel.)
LLM_API_KEY=
# Reasoning models (the deterministic MCP path needs no tool-calling).
MODEL_RESEARCH=qwen2.5:14b
MODEL_PROPOSAL=qwen2.5:14b
MODEL_TRACKING=qwen2.5:14b
# Per-request LLM ceiling and retry count. LLM calls are serialized process-wide,
# so a slow shared ollama box doesn't get dogpiled by concurrent passes.
LLM_TIMEOUT_MS=240000
LLM_RETRIES=1

# --- Web search (pluggable; replaces the old hosted web_search) -----------
# provider: none | tavily | brave | searxng
SEARCH_PROVIDER=none
# API key for tavily/brave (or save it in the dashboard Credentials panel).
SEARCH_API_KEY=
# Base URL for a self-hosted SearXNG instance (provider=searxng).
SEARCH_BASE_URL=
SEARCH_MAX_RESULTS=5
# News recency window in days (Tavily). Smaller = fresher, fewer results.
SEARCH_RECENCY_DAYS=14

# --- Robinhood MCP -------------------------------------------------------
# The public MCP endpoint. A local MCP client (mcp/robinhood-client.js) connects
# here directly — Robinhood access no longer goes through Anthropic.
ROBINHOOD_MCP_URL=https://agent.robinhood.com/mcp/trading
# OAuth bearer token. Mint with: node scripts/get-robinhood-token.mjs
# (or save it from the dashboard Credentials panel).
ROBINHOOD_MCP_TOKEN=
# Auto-refresh material. The mint script saves these to the DB for you; you
# normally don't set them by hand. With them present, the desk renews an expired
# access token automatically instead of failing with auth errors.
ROBINHOOD_REFRESH_TOKEN=
ROBINHOOD_OAUTH_CLIENT_ID=
ROBINHOOD_TOKEN_ENDPOINT=
# The brokerage account number trades run against. Must be agentic_allowed=true.
ROBINHOOD_ACCOUNT=

# --- What the desk watches ----------------------------------------------
# Comma-separated universe the research pass covers each cycle.
# Equities/ETFs by symbol; crypto with a -USD suffix (e.g. BTC-USD,ETH-USD).
WATCH_UNIVERSE=AAPL,NVDA,MSFT,SPY,BTC-USD,ETH-USD
# If true, the research pass also pulls in everything on your Robinhood watchlists.
INCLUDE_ROBINHOOD_WATCHLISTS=true

# --- Breakout discovery --------------------------------------------------
# Pulls fresh candidate symbols from movers/news/earnings into the research
# universe so the desk catches names that aren't on your watchlist yet.
DISCOVERY_ENABLED=true
DISCOVERY_SOURCES=movers,news,earnings   # any of: movers,news,earnings
DISCOVERY_MAX_NEW=8            # new names admitted per discovery run
DISCOVERY_MAX_TRACKED=30       # ceiling on the auto-discovered universe
DISCOVERY_MAX_AGE_DAYS=14      # drop discovered names not re-seen within this many days
DISCOVERY_MIN_PRICE=1          # skip penny names below this price
DISCOVERY_MAX_PRICE=2000       # skip ultra-high-priced names above this
DISCOVERY_MIN_DOLLAR_VOL=1000000  # min avg daily $-volume (price x avg volume) — liquidity floor

# --- Risk rails (enforced before any proposal is written) ----------------
MAX_POSITION_USD=2000          # largest single position the desk may propose
MAX_NEW_TRADES_PER_DAY=5       # cap on proposals generated per day
MAX_DAILY_LOSS_USD=500         # if realized+unrealized day P&L breaches this, desk halts new proposals
# Concentration caps (0 = disabled). Total cost-basis exposure to one symbol /
# one sector — held + the proposed add — may not exceed these.
MAX_SYMBOL_EXPOSURE_USD=0
MAX_SECTOR_EXPOSURE_USD=0
ALLOW_OPTIONS=true
ALLOW_CRYPTO=true
# Equity proposals are only generated during these ET hours unless crypto.
MARKET_OPEN_ET=09:30
MARKET_CLOSE_ET=16:00

# --- Scheduler cadence (minutes) ----------------------------------------
RESEARCH_EVERY_MIN=60
TRACKING_EVERY_MIN=15
PROPOSAL_EVERY_MIN=30
DISCOVERY_EVERY_MIN=120

# --- Server --------------------------------------------------------------
PORT=8787
# Bind to your Tailscale interface so the dashboard is private to your tailnet.
# Use 0.0.0.0 only if you front it with auth. Default below = localhost only.
HOST=127.0.0.1
# A shared secret required by the dashboard to approve/reject/place. Set anything long.
CONTROL_TOKEN=change-me-to-a-long-random-string

# --- Master switch -------------------------------------------------------
# When false, the scheduler runs research/tracking/proposals but NEVER allows
# placement even on approval. Flip to true once you trust it.
PLACEMENT_ENABLED=false
